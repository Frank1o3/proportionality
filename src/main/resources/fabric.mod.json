{
	"schemaVersion": 1,
	"id": "proportionality",
	"version": "${version}",
	"name": "Proportionality",
	"description": "A server-side and client-side Minecraft mod that lets players scale their size and automatically adjusts their attributes proportionally.",
	"authors": [
		"Frank1o3"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/proportionality/",
		"sources": "https://github.com/Frank1o3/Proportionality",
		"issues": "https://github.com/Frank1o3/Proportionality/issues"
	},
	"license": "MIT",
	"icon": "assets/proportionality/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"frank1o3.statscale.Proportionality"
		],
		"client": [
			"frank1o3.statscale.client.ProportionalityClient"
		]
	},
	"mixins": [
		{
			"config": "proportionality.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}